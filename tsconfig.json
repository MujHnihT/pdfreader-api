{
    "compilerOptions": {
      "target": "ES6",
      "module": "commonjs",
      "esModuleInterop": true,
      "allowSyntheticDefaultImports": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
      "outDir": "./dist",
      "rootDir": "./src",
      "typeRoots": [
        "./node_modules/@types",
        "./src/cores/types"
      ],
      "moduleResolution": "node",
      "resolveJsonModule": true,
      "strict": true,
      "noImplicitAny": true,
      "skipDefaultLibCheck": true
    },
    "include": [
      "src/**/*.ts"
    ],
    "exclude": [
      "node_modules"
    ]
  }
  