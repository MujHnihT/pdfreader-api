PORT=3000
VERSION=1.0.0

# Run every 15 minutes.
CRON_ENABLED=true
CRON_EXPRESSION=*/5 * * * *
TIMEZONE=Asia/Ho_Chi_Minh

# Leave SCAN_SYMBOLS empty to scan top USDT pairs by 24h quote volume.
SCAN_SYMBOLS=
MAX_SYMBOLS=50
SCAN_CONCURRENCY=5
BINANCE_BASE_URL=https://fapi.binance.com

# Pine settings
VOL_LEN=20
VOL_MULT_AVG=1.2
VOL_MULT_PREV=1.0
# AND = 1H and 2H, OR = 1H or 2H
VOL_MODE=AND
NEED_CLOSE_CONFIRM=false
SL_LOOKBACK_1H=6
REWARD_RISK=0.3
MAX_HOLD_HOURS=4
TELEGRAM_SEND_MESSAGE_URL=
TELEGRAM_BOT_TOKEN=8623183516:AAF5cGDMZ2j9a0GN8sqRuk5eoFtUYUW0Jvo
TELEGRAM_CHAT_ID=1527439399
