{
  "version": 2,
  "builds": [
    {
      "src": "src/index.ts",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 60
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/index.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/vercel",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/price-jumps",
      "schedule": "0 * * * *"
    }
  ]
}
